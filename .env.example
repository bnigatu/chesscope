# Turso libSQL connection.
#
# Get these from `turso db show chesscope --url` and
# `turso db tokens create chesscope`, or from the Turso dashboard.
#
# Used locally by Drizzle (db:push) and by the Python ingestion script.
# In production, these are set as Cloudflare Worker secrets via
# `wrangler secret put TURSO_URL` / `wrangler secret put TURSO_AUTH_TOKEN`.

TURSO_URL=libsql://chesscope-USERNAME.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...

# Lichess Opening Explorer access uses per-user OAuth — each user
# connects their own Lichess account in-app. No environment variable
# is needed for that flow.
